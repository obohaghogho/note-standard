# ─── Note Standard — Backend Environment Variables ───────────
# Copy this file to .env and fill in real values.
# NEVER commit .env — only .env.example is tracked in Git.

# ── App ──────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000
DEBUG=false
CLIENT_URL=https://notestandard.com
SERVER_URL=https://your-render-url.onrender.com

# ── Security ─────────────────────────────────────────────────
BCRYPT_SALT_ROUNDS=12
RATE_LIMIT_WINDOW_MS=600000
RATE_LIMIT_MAX=100
EMAIL_RATE_LIMIT=5
EMAIL_RATE_WINDOW_MIN=15

# ── Logging ──────────────────────────────────────────────────
# Levels: error, warn, info, debug
LOG_LEVEL=info

# ── Database / Supabase ──────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/dbname
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_anon_key
SUPABASE_SERVICE_KEY=your_supabase_service_role_key

# ── Auth ─────────────────────────────────────────────────────
JWT_SECRET=your_jwt_secret
RECAPTCHA_SECRET_KEY=your_recaptcha_secret

# ── Flutterwave ──────────────────────────────────────────────
FLUTTERWAVE_SECRET_KEY=FLWSECK-xxxxxxxxxxxx
FLW_SECRET_HASH=your_flw_webhook_hash
FLUTTERWAVE_WEBHOOK_SECRET=your_flw_webhook_secret

# ── Paystack ─────────────────────────────────────────────────
PAYSTACK_SECRET_KEY=sk_test_xxxxxxxxxxxx

# ── Korapay ──────────────────────────────────────────────────
KORAPAY_SECRET_KEY=your_korapay_secret
KORAPAY_PUBLIC_KEY=your_korapay_public
KORAPAY_WEBHOOK_SECRET=your_korapay_webhook_secret

# ── NOWPayments (Crypto) ─────────────────────────────────────
NOWPAYMENTS_API_KEY=your_nowpayments_api_key
NOWPAYMENTS_IPN_SECRET=your_nowpayments_ipn_secret
NOWPAYMENTS_BASE_URL=https://api.nowpayments.io
NOWPAYMENTS_WEBHOOK_URL=https://your-server.com/api/webhooks/nowpayments

# ── Exchange Rates ───────────────────────────────────────────
EXCHANGERATE_API_KEY=your_exchangerate_api_key

# ── Crypto (future — blockchain RPC) ────────────────────────
# CRYPTO_RPC_URL=https://mainnet.infura.io/v3/YOUR_KEY
# CRYPTO_PROVIDER=nowpayments

# ── Email (SMTP) ─────────────────────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
# Set to true if using port 465, false for port 587
SMTP_SECURE=false
SMTP_USER=your_email@example.com
SMTP_PASS=your_email_password
EMAIL_FROM=noreply@notestandard.com

# ── Push Notifications (VAPID) ───────────────────────────────
VAPID_PUBLIC_KEY=your_vapid_public_key
VAPID_PRIVATE_KEY=your_vapid_private_key

# ── Agora (Video/Voice Calls) ───────────────────────────────
AGORA_APP_ID=your_agora_app_id
AGORA_APP_CERTIFICATE=your_agora_app_certificate
