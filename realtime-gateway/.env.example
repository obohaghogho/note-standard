# Realtime Gateway Configuration
PORT=5000
NODE_ENV=development

# Database Configuration
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Supabase Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Push Notifications (VAPID — Web only)
VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
EMAIL_FROM=noreply@notestandard.com

# ── Firebase Admin (FCM — Android push notifications) ─────────────────────────
# Option A — Paste the entire service-account JSON as a single-line string:
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"...","client_id":"...","auth_uri":"...","token_uri":"..."}
#
# Option B — Individual fields (use when Option A is awkward in your CI/CD):
# FIREBASE_PROJECT_ID=your-firebase-project-id
# FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxx@your-project.iam.gserviceaccount.com
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# ── Apple Push Notification service (APNs — iOS push notifications) ───────────
# Download the .p8 key from Apple Developer → Certificates, Identifiers & Profiles
# → Keys → Create a key with "Apple Push Notifications service (APNs)" capability.
#
# APNS_KEY: Paste the full contents of the .p8 file (newlines as \n):
APNS_KEY="-----BEGIN PRIVATE KEY-----\nMIGH...\n-----END PRIVATE KEY-----\n"
# APNS_KEY_ID: The 10-character Key ID shown in Apple Developer Portal
APNS_KEY_ID=XXXXXXXXXX
# APNS_TEAM_ID: Your 10-character Apple Developer Team ID (top-right of portal)
APNS_TEAM_ID=XXXXXXXXXX
# APNS_BUNDLE_ID: Your app's bundle identifier (e.g. com.yourcompany.appname)
APNS_BUNDLE_ID=com.notestandard.app

# ── TURN / STUN Server (REQUIRED for calls over LTE / behind NAT) ─────────────
# Without TURN, calls between different mobile carriers will always fail.
#
# Option A — Managed (Metered.ca, free tier available):
#   TURN_HOST=your-subdomain.metered.live
#   TURN_SECRET=your-metered-api-key
#
# Option B — Self-hosted Coturn:
#   TURN_HOST=YOUR_SERVER_IP_OR_DOMAIN
#   TURN_SECRET=your-strong-random-secret   # must match coturn --static-auth-secret
#
TURN_HOST=
TURN_SECRET=
# Optional: enable TLS TURN on port 443 (for corporate firewalls)
TURN_TLS_ENABLED=false
# Credential TTL in seconds (default 86400 = 24h)
TURN_CREDENTIAL_TTL=86400
