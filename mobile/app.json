{
  "expo": {
    "name": "NoteStandard",
    "slug": "mobile",
    "version": "1.6.4",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": false,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1E40AF"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.notestandard.app",
      "infoPlist": {
        "UIBackgroundModes": [
          "voip",
          "remote-notification",
          "audio",
          "processing",
          "voip",
          "remote-notification",
          "audio",
          "processing"
        ]
      }
    },
    "android": {
      "package": "com.notestandard.app",
      "googleServicesFile": "./google-services.json",
      "minSdkVersion": 23,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1E40AF"
      },
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.MANAGE_OWN_CALLS",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.USE_FULL_SCREEN_INTENT",
        "android.permission.BIND_TELECOM_CONNECTION_SERVICE",
        "android.permission.INTERNET",
        "android.permission.ACCESS_NETWORK_STATE",
        "android.permission.READ_PHONE_STATE",
        "android.permission.CALL_PHONE"
      ],
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "softwareKeyboardLayoutMode": "adjustResize"
    },
    "plugins": [
      "expo-notifications",
      "@react-native-firebase/app",
      "@react-native-firebase/messaging",
      "./plugins/withAndroidNativeCall",
      "./plugins/withIOSVoIP",
      [
        "@config-plugins/react-native-callkeep",
        {
          "ios": {
            "appName": "NoteStandard"
          },
          "android": {
            "selfManaged": true,
            "foregroundService": {
              "channelId": "com.notestandard.app.calls",
              "channelName": "Incoming Calls",
              "notificationTitle": "Incoming Call",
              "notificationIcon": "ic_launcher"
            }
          }
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "00352001-c4c1-42ad-9cf1-48e8e50aced7"
      }
    },
    "owner": "aghogho107",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/a469327a-6f7b-4162-bf2c-278ea97226ee"
    }
  }
}
