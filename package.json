{
  "name": "note-standard",
  "version": "1.0.0",
  "description": "Root package for note-standard monorepo",
  "scripts": {
    "install:all": "npm install && npm install -w client && npm install -w server",
    "build": "npm run build -w client",
    "start": "node server/index.js",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "client": "npm run dev -w client",
    "server": "npm run dev -w server",
    "build:client": "npm run build -w client",
    "lint": "npm run lint --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "prepare": "echo 'Skipping husky in production'"
  },
  "dependencies": {
    "bip39": "^3.1.0",
    "cors": "^2.8.5",
    "express": "^5.2.1",
    "husky": "^9.1.7"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "is-ci": "^4.1.0"
  },
  "workspaces": [
    "client",
    "server"
  ],
  "engines": {
    "node": ">=20.0.0"
  }
}
