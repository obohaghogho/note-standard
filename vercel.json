{
  "buildCommand": "cd client && npm install && npm run build",
  "outputDirectory": "client/dist",
  "installCommand": "npm install",
  "routes": [
    { "src": "/(fincra-verification\\.txt)", "dest": "/$1" },
    { "src": "/.well-known/(.*)", "dest": "/.well-known/$1" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
