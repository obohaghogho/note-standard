# ─── Note Standard — Frontend Environment Variables ──────────
# Copy this file to .env and fill in real values.
# Only VITE_* variables are exposed to the browser — these are PUBLIC keys only.
# NEVER put secret keys here.

# ── API ──────────────────────────────────────────────────────
VITE_API_URL=process.env.API_URL

# ── Supabase (public keys only) ──────────────────────────────
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# ── Agora (public App ID only) ───────────────────────────────
VITE_AGORA_APP_ID=your_agora_app_id

# ── Push Notifications (public VAPID key only) ───────────────
VITE_VAPID_PUBLIC_KEY=your_vapid_public_key

# ── reCAPTCHA (public site key only) ─────────────────────────
VITE_RECAPTCHA_SITE_KEY=your_recaptcha_site_key

# ── App URLs ─────────────────────────────────────────────────
VITE_CLIENT_URL=https://notestandard.com
