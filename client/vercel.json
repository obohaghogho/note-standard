{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "routes": [
    { "src": "/(fincra-verification\\.txt)", "dest": "/$1" },
    { "src": "/.well-known/(.*)", "dest": "/.well-known/$1" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
